{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":disableDependencyDashboard",
		"security:minimumReleaseAgeNpm",
		"helpers:pinGitHubActionDigestsToSemver"
	],
	"rangeStrategy": "bump",
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch", "digest"],
			"automerge": true
		},
		{
			"matchManagers": "mise",
			"minimumReleaseAge": "3 days"
		},
		{
			"matchManagers": "github-actions",
			"minimumReleaseAge": "7 days"
		},
		{
			"description": "Only update AI-SDK packages on Sunday",
			"matchPackageNames": ["ai", "@ai-sdk/*"],
			"schedule": ["* 0-23 * * 0"]
		},
		{
			"matchPackageNames": ["oxlint", "oxfmt"],
			"groupName": "oxc ecosystem"
		},
		{
			"description": "Disable minimum release age checks for internal dependencies",
			"matchPackageNames": ["@unownplain/*", "UnownPlain/*"],
			"minimumReleaseAge": null
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/(^|/)package.json$/"],
			"depNameTemplate": "bun",
			"datasourceTemplate": "npm",
			"versioningTemplate": "npm",
			"matchStrings": ["\"packageManager\":\\s+\"bun@(?<currentValue>\\d+\\.\\d+\\.\\d+)\""]
		},
		{
			"customType": "regex",
			"managerFilePatterns": ["/(^|/)\\.github/workflows/[^/]+\\.ya?ml$/"],
			"depNameTemplate": "mise",
			"packageNameTemplate": "jdx/mise",
			"datasourceTemplate": "github-releases",
			"versioningTemplate": "semver",
			"extractVersionTemplate": "^v(?<version>.*)$",
			"matchStrings": [
				"uses:\\s+jdx/mise-action@[^\\s#]+(?:\\s+#[^\\r\\n]*)?\\r?\\n\\s+with:\\r?\\n\\s+version:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)"
			]
		}
	]
}
