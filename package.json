{
	"name": "anthelion",
	"private": "true",
	"description": "Scripts and tools used to automatically update some packages in the Windows Package Manager Community Repository",
	"license": "MIT",
	"author": "UnownPlain",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"start": "bun src/main.ts",
		"pkgtest": "bun src/test.ts",
		"format": "oxfmt",
		"lint": "oxlint --type-check --type-aware",
		"gen-schema": "bun run src/schema/generate.ts && oxfmt"
	},
	"dependencies": {
		"@ai-sdk/groq": "3.0.31",
		"@rcompat/fs": "0.27.1",
		"@unownplain/anthelion-komac": "0.0.21",
		"ai": "6.0.140",
		"ansis": "4.2.0",
		"es-toolkit": "1.45.1",
		"ky": "1.14.3",
		"octokit": "5.0.5",
		"temporal-polyfill": "0.3.2",
		"yaml": "2.8.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.11",
		"oxfmt": "0.42.0",
		"oxlint": "1.57.0",
		"oxlint-tsgolint": "0.18.1"
	},
	"packageManager": "bun@1.3.11"
}
