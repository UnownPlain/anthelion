{
	"name": "anthelion",
	"private": "true",
	"description": "Scripts and tools used to automatically update some packages in the Windows Package Manager Community Repository",
	"license": "MIT",
	"author": "UnownPlain",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"start": "bun run --experimental-http2-fetch src/main.ts",
		"pkgtest": "bun run --experimental-http2-fetch src/test.ts",
		"format": "bun --bun oxfmt",
		"lint": "bun --bun oxlint --type-check --type-aware",
		"gen-schema": "bun run src/schema/generate.ts && bun format"
	},
	"dependencies": {
		"@ai-sdk/groq": "3.0.40",
		"@rcompat/fs": "0.34.0",
		"@unownplain/anthelion-komac": "0.0.43",
		"ai": "6.0.202",
		"ansis": "4.3.1",
		"es-toolkit": "1.47.1",
		"ky": "2.0.2",
		"octokit": "5.0.5",
		"temporal-polyfill": "0.3.2",
		"yaml": "2.9.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"oxlint-tsgolint": "0.23.0"
	},
	"packageManager": "bun@1.3.14"
}
