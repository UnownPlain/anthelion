{
	"name": "anthelion",
	"private": "true",
	"description": "Scripts and tools used to automatically update some packages in the Windows Package Manager Community Repository",
	"license": "MIT",
	"author": "UnownPlain",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"start": "bun src/main.ts",
		"pkgtest": "bun src/test.ts",
		"format": "bun --bun oxfmt",
		"lint": "bun --bun oxlint --type-check --type-aware",
		"gen-schema": "bun src/schema/generate.ts && bun format"
	},
	"dependencies": {
		"@ai-sdk/groq": "3.0.39",
		"@rcompat/fs": "0.33.2",
		"@unownplain/anthelion-komac": "0.0.35",
		"ai": "6.0.176",
		"ansis": "4.2.0",
		"es-toolkit": "1.46.1",
		"ky": "2.0.2",
		"octokit": "5.0.5",
		"temporal-polyfill": "0.3.2",
		"yaml": "2.8.4",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/bun": "1.3.13",
		"oxfmt": "0.48.0",
		"oxlint": "1.63.0",
		"oxlint-tsgolint": "0.22.1"
	},
	"packageManager": "bun@1.3.13"
}
