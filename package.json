{
	"name": "anthelion",
	"private": "true",
	"description": "Scripts and tools used to automatically update some packages in the Windows Package Manager Community Repository",
	"license": "MIT",
	"author": "UnownPlain",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"start": "bun src/main.ts",
		"pkgtest": "bun src/test.ts",
		"format": "bun --bun oxfmt",
		"lint": "bun --bun oxlint --type-check --type-aware",
		"gen-schema": "bun src/schema/generate.ts && bun format"
	},
	"dependencies": {
		"@ai-sdk/groq": "3.0.32",
		"@rcompat/fs": "0.29.0",
		"@unownplain/anthelion-komac": "0.0.26",
		"ai": "6.0.143",
		"ansis": "4.2.0",
		"es-toolkit": "1.45.1",
		"ky": "2.0.0",
		"octokit": "5.0.5",
		"temporal-polyfill": "0.3.2",
		"yaml": "2.8.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.12",
		"oxfmt": "0.44.0",
		"oxlint": "1.59.0",
		"oxlint-tsgolint": "0.20.0"
	},
	"packageManager": "bun@1.3.12"
}
