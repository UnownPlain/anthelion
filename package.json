{
	"name": "anthelion",
	"private": "true",
	"description": "Scripts and tools used to automatically update some packages in the Windows Package Manager Community Repository",
	"license": "MIT",
	"author": "UnownPlain",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"start": "bun src/main.ts",
		"pkgtest": "bun src/test.ts",
		"format": "oxfmt",
		"lint": "oxlint --type-check --type-aware",
		"gen-schema": "bun run src/schema/generate.ts && oxfmt"
	},
	"dependencies": {
		"@ai-sdk/cerebras": "2.0.37",
		"@rcompat/fs": "0.25.2",
		"@unownplain/anthelion-komac": "0.0.13",
		"ai": "6.0.109",
		"ansis": "4.2.0",
		"dot-prop": "10.1.0",
		"es-toolkit": "1.45.1",
		"ky": "1.14.3",
		"octokit": "5.0.5",
		"temporal-polyfill": "0.3.0",
		"yaml": "2.8.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.10",
		"@types/node": "25.3.3",
		"oxfmt": "0.36.0",
		"oxlint": "1.51.0",
		"oxlint-tsgolint": "0.16.0"
	},
	"packageManager": "bun@1.3.10"
}
