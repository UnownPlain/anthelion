{
	"$schema": "https://anthelion.unownplain.dev/schema.json",
	"strategy": "page-match",
	"pageMatch": {
		"url": "https://certifytheweb.com/",
		"regex": "certifythewebsetup[._-]v?(\\d+(?:\\.\\d+)+)\\.exe"
	},
	"urls": [
		"https://downloads.certifytheweb.com/release/{version}.0/certify-ccm-windows-x64-{version}.0.exe"
	]
}
