{
	"$schema": "https://anthelion.unownplain.dev/schema.json",
	"strategy": "redirect-match",
	"redirectMatch": {
		"url": "https://links.extensis.com/extensis_connect/ec_latest?language=en&platform=win",
		"regex": "ExtensisConnect-W-(\\d+(?:-\\d+)+)\\.zip"
